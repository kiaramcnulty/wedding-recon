# --- Supabase (from Settings -> API in your Supabase project) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Server-only. Never expose to the client. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Google Places API (server-side only; used for business search in Add Recon) ---
GOOGLE_PLACES_API_KEY=your-places-api-key

# --- App ---
# Used for share deeplinks and auth redirects. http://localhost:3000 in dev.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Map tiles ---
# OpenFreeMap needs no key. If you switch to MapTiler, set its style URL/key here.
NEXT_PUBLIC_MAP_STYLE_URL=https://tiles.openfreemap.org/styles/liberty
