# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# claude code local session dir (but keep shared skills + agents tracked)
.claude/*
!.claude/skills/
!.claude/agents/

# supabase cli local state
supabase/.temp/
supabase/.branches/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local product-spec artifacts (canonical text spec lives in docs/wedding-recon-spec.txt)
/Wedding Recon Spec.pdf
/Wedding Recon Spec.md

# launchvenues skill working artifacts (pre-rename venue workdirs)
/data/launchvenues/

# launchvendors skill working artifacts
/data/launchvendors/

# enrichvenues skill working artifacts (legacy venue workdirs + shared rosters)
/data/enrichvenues/

# enrichvendors skill working artifacts
/data/enrichvendors/
